rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null && request.auth.token.email is string;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function userDocPath() {
      return /databases/(default)/documents/users/$(userEmail());
    }

    function hasUserDoc() {
      return signedIn() && firestore.exists(userDocPath());
    }

    function userDoc() {
      return firestore.get(userDocPath());
    }

    function isAdmin() {
      return hasUserDoc() && userDoc().data.role == 'admin';
    }

    function canAccessMainVault() {
      return isAdmin() ||
        (
          hasUserDoc() &&
          (
            userDoc().data.accessLevel == 'premium' ||
            userDoc().data.subscriptionStatus in ['active', 'trial']
          )
        );
    }

    match /free_pdfs/{fileName=**} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /vault_pdfs/{fileName=**} {
      allow read: if canAccessMainVault();
      allow create, update, delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
